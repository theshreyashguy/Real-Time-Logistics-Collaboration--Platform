# Copy to backend/.env (and frontend/.env.local where noted) and fill in.

# --- Database (Postgres) ---
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/hemut

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
JWT_SECRET=replace-with-a-random-256-bit-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# --- AI (optional) ---
# Leave ANTHROPIC_API_KEY empty to use the deterministic extractive summarizer
# (no network, no cost). Set it to switch to Claude-backed summaries.
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

# --- Realtime / limits ---
PRESENCE_TTL=30
RATE_LIMIT_MESSAGES=30
RATE_LIMIT_WINDOW=10

# --- Optional outbound webhook for shipment-tagged messages ---
SHIPMENT_WEBHOOK_URL=

# --- CORS (frontend origin) ---
CORS_ORIGINS=http://localhost:3000

# --- Frontend (put in frontend/.env.local) ---
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
